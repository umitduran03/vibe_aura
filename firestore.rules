rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Özel Kullanıcı Verisi (Sadece Sahibine Açık)
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Açık Analiz Sonuçları
    match /results/{documentId} {
      // Herkestan paylaşım linkiyle okunabilir
      allow read: if true;
      // Yeni yazdırma işlemleri yalnızca yetkili ve dokümana UID'sini ekleyenlere açık
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      // Sadece dokumanın sahibi güncelleyebilir veya silebilir
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
